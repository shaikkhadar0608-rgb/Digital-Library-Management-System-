# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection (Replace with your actual MongoDB connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/digilib_db?retryWrites=true&w=majority

# Security Keys
JWT_SECRET=your_super_secure_random_string_2026_digilib_secret_key
JWT_EXPIRES_IN=30d

# Frontend URL (For CORS configuration if running separately)
FRONTEND_URL=http://localhost:5500